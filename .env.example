# Copie para .env e preencha. NUNCA versione o .env real (já está no .gitignore).

# OpenAI (obrigatório)
OPENAI_API_KEY=

# MongoDB Atlas (obrigatório) — leads + jobs + arte (GridFS)
MONGODB_URI=
MONGODB_DB=visadream

# Anti-bot Cloudflare Turnstile (opcional — ativa quando preenchido)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# Fila offline (eventos com internet instável) — permite sync sem captcha imediato
ALLOW_OFFLINE_QUEUE=1

# HubSpot (opcional)
HUBSPOT_TOKEN=

# Painel admin de leads (/admin)
ADMIN_PASSWORD=

# Imagem
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=medium

# Servidor
PORT=8002
